  function generateWeeks(numWeeks, startDateStr, internatos) {
    const startDate = new Date(startDateStr + 'T00:00:00');
    const weeks = [];

    // Determine phases from internatos or defaults
    let phases = [];
    if (internatos && internatos.length > 0) {
      internatos.forEach(i => { if (i.nome && i.inicio) phases.push({ name: i.nome, start: new Date(i.inicio + 'T00:00:00') }); });
      phases.sort((a, b) => a.start - b.start);
    }

    // Distribute tasks proportionally
    const tasksPerWeek = Math.max(4, Math.min(8, Math.ceil(taskPool.length / numWeeks)));
    let taskIdx = 0;

    // Determine simulado weeks (every ~10 weeks, and last week)
    const simuladoWeeks = new Set();
    for (let i = 10; i <= numWeeks; i += 10) simuladoWeeks.add(i);
    simuladoWeeks.add(numWeeks);

    for (let w = 1; w <= numWeeks; w++) {
      const wStart = new Date(startDate);
      wStart.setDate(startDate.getDate() + (w - 1) * 7);

      // Determine phase for this week
      let phase = 'Estudos';
      if (phases.length > 0) {
        for (let p = phases.length - 1; p >= 0; p--) {
          if (wStart >= phases[p].start) { phase = phases[p].name; break; }
        }
      }

      // Pick tasks for this week
      const tasks = [];
      const count = simuladoWeeks.has(w) ? Math.min(tasksPerWeek - 1, 5) : Math.min(tasksPerWeek, taskPool.length - taskIdx);

      for (let t = 0; t < count && taskIdx < taskPool.length; t++, taskIdx++) {
        tasks.push({
          id: `task_${w}_${t}_${Date.now() + t}`,
          category: taskPool[taskIdx].category,
          subject: taskPool[taskIdx].subject
        });
      }

      // Add simulado
      if (simuladoWeeks.has(w)) {
        tasks.push({ id: `sim_${w}_${Date.now()}`, category: 'Simulado', subject: `Simulado ${[...simuladoWeeks].indexOf(w) + 1}` });
      }

      // Title from first task category or phase
      const title = tasks.length > 0 ? tasks[0].subject.split(' ').slice(0, 3).join(' ') : 'Revisão';

      // Default agenda
      const agenda = {};
      const timeSlots = ['07:00 - 12:00', '13:00 - 17:00', '17:00 - 19:00', '19:00 - 21:00'];
      ['d1','d2','d3','d4','d5'].forEach(d => {
        agenda[`${d}_s0`] = { text: 'Estudo', color: '#dcfce7' };
      });

      weeks.push({ week: w, phase, title, tasks, agenda, timeSlots });
    }

    return weeks;
  }

  // ── CONFIRM & SAVE ────────────────────────────────────────────────────────
  async function confirmarOnboarding() {
    const btn = document.getElementById('btn-iniciar');
    btn.disabled = true;
    btn.textContent = 'Salvando...';

    const errEl = document.getElementById('save-error');
    errEl.classList.remove('show');

    const nome       = document.getElementById('f-nome').value.trim();
    const prova      = document.getElementById('f-prova').value;
    const inicioStr  = document.getElementById('f-inicio').value;
    const provaData  = document.getElementById('f-prova-data').value;
    const internatos = selectedValues.internato === 'sim' ? getInternatos() : [];

    try {
      // 1. Generate the dynamic week structure
      const weeks = generateWeeks(weekCount, inicioStr, internatos);

      // 2. Build initial state
      const initialState = {
        weeks,
        progress: {},
        dailyStats: {},
        highYieldProgress: {},
        onboardingData: {
          nome, prova, inicioStr, provaData,
          horas: selectedValues.ritmo,
          internato: selectedValues.internato,
          internatos,
          weekCount,
          startDate: inicioStr
        }
      };

      // 3. Save onboarding record
      const { error: obError } = await sb.from('onboarding').upsert({
        user_id: currentUser.id,
        prova,
        data_prova: provaData,
        inicio: inicioStr,
        horas_dia: selectedValues.ritmo,
        template: 'personalizado',
        completed: true
      });

      if (obError) throw obError;

      // 4. Save cronograma to cloud
      const { error: cronError } = await sb.from('cronogramas').upsert({
        user_id: currentUser.id,
        state_data: initialState
      });

      if (cronError) throw cronError;

      // 5. Update profile name
      await sb.from('profiles').update({ nome }).eq('id', currentUser.id);

      // 6. Done → go to cronograma
      window.location.href = 'cronograma.html';

    } catch (e) {
      console.error(e);
      showErr(errEl, 'Erro ao salvar. Tente novamente: ' + (e.message || e));
      btn.disabled = false;
      btn.textContent = 'Começar minha jornada →';
    }
  }
