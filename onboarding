<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CronoMed — Configurar meu cronograma</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root {
      --green: #00c27a; --green-d: #009f64; --green-light: #e6fff5;
      --dark: #0a0f0d; --dark2: #111a15; --mid: #1e2e25;
      --text: #e8f0eb; --muted: #7a9e8a; --white: #ffffff;
      --step-active: #00c27a; --step-done: #059669; --step-inactive: #334155;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; }
    h1, h2, h3 { font-family: 'Fraunces', Georgia, serif; }

    /* Background glow */
    .bg-glow { position: fixed; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(0,194,122,0.12) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; z-index: 0; }

    /* HEADER */
    header { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(10,15,13,0.9); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(0,194,122,0.1); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
    .logo { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 900; color: var(--white); text-decoration: none; }
    .logo span { color: var(--green); }
    .header-step { font-size: 0.75rem; color: var(--muted); font-weight: 600; }

    /* MAIN CONTAINER */
    .container { max-width: 600px; margin: 0 auto; padding: 7rem 1.5rem 3rem; position: relative; z-index: 1; }

    /* PROGRESS BAR */
    .progress-track { width: 100%; height: 3px; background: rgba(255,255,255,0.08); border-radius: 100px; margin-bottom: 3rem; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, var(--green), var(--green-d)); border-radius: 100px; transition: width 0.5s cubic-bezier(0.4,0,0.2,1); }

    /* STEP PANEL */
    .step-panel { display: none; animation: fadeSlide 0.4s ease; }
    .step-panel.active { display: block; }
    @keyframes fadeSlide { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    .step-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(0,194,122,0.12); border: 1px solid rgba(0,194,122,0.25); color: var(--green); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 100px; margin-bottom: 1.25rem; }
    .step-title { font-size: clamp(1.8rem, 5vw, 2.5rem); font-weight: 900; color: var(--white); line-height: 1.1; margin-bottom: 0.75rem; }
    .step-sub { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin-bottom: 2.5rem; font-weight: 300; }

    /* FORM ELEMENTS */
    .field { margin-bottom: 1.5rem; }
    .field label { display: block; font-size: 0.78rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; }
    .field input[type="text"],
    .field input[type="date"],
    .field input[type="email"],
    .field select {
      width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px; padding: 0.95rem 1.1rem; color: var(--white); font-size: 1rem;
      font-family: 'DM Sans', sans-serif; outline: none; transition: border-color 0.2s, background 0.2s;
    }
    .field input:focus, .field select:focus { border-color: var(--green); background: rgba(0,194,122,0.05); }
    .field input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1) opacity(0.4); cursor: pointer; }
    .field select option { background: #1e2e25; color: white; }

    /* WEEK PREVIEW PILL */
    .week-preview { background: rgba(0,194,122,0.1); border: 1px solid rgba(0,194,122,0.25); border-radius: 14px; padding: 1rem 1.4rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; transition: all 0.3s; }
    .week-preview.hidden { display: none; }
    .week-preview-num { font-family: 'Fraunces', serif; font-size: 2.5rem; font-weight: 900; color: var(--green); line-height: 1; }
    .week-preview-label { font-size: 0.78rem; color: var(--muted); }
    .week-preview-label strong { display: block; font-size: 0.95rem; color: var(--text); font-weight: 700; margin-bottom: 0.2rem; }
    .week-preview-label.warn strong { color: #fbbf24; }

    /* OPTION CARDS */
    .options-grid { display: grid; gap: 0.85rem; margin-bottom: 2rem; }
    .option-card {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px; padding: 1.2rem 1.4rem; cursor: pointer;
      transition: all 0.2s; display: flex; align-items: flex-start; gap: 1rem;
      user-select: none;
    }
    .option-card:hover { border-color: rgba(0,194,122,0.4); background: rgba(0,194,122,0.05); }
    .option-card.selected { border-color: var(--green); background: rgba(0,194,122,0.1); }
    .option-card.selected .option-radio { background: var(--green); border-color: var(--green); }
    .option-card.selected .option-radio::after { opacity: 1; }
    .option-radio {
      width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2);
      flex-shrink: 0; margin-top: 2px; position: relative; transition: all 0.2s;
    }
    .option-radio::after {
      content: ''; position: absolute; width: 8px; height: 8px; background: white;
      border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%,-50%); opacity: 0; transition: opacity 0.2s;
    }
    .option-title { font-weight: 700; color: var(--white); font-size: 0.95rem; margin-bottom: 0.25rem; }
    .option-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }
    .option-emoji { font-size: 1.6rem; flex-shrink: 0; }

    /* INTERNATO ROWS */
    .internato-list { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
    .internato-row { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 1rem 1.2rem; display: grid; grid-template-columns: 1fr auto auto; gap: 0.75rem; align-items: center; }
    .internato-row select, .internato-row input { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 0.5rem 0.75rem; color: var(--white); font-size: 0.82rem; font-family: 'DM Sans', sans-serif; outline: none; }
    .internato-row input[type="date"] { font-size: 0.78rem; }
    .internato-row button { width: 28px; height: 28px; border-radius: 8px; border: none; background: rgba(239,68,68,0.15); color: #f87171; cursor: pointer; font-size: 0.85rem; transition: background 0.2s; flex-shrink: 0; }
    .internato-row button:hover { background: rgba(239,68,68,0.3); }
    .btn-add-internato { width: 100%; padding: 0.85rem; border: 1px dashed rgba(0,194,122,0.3); background: transparent; color: var(--green); font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 0.85rem; border-radius: 12px; cursor: pointer; transition: all 0.2s; margin-bottom: 1.5rem; }
    .btn-add-internato:hover { background: rgba(0,194,122,0.08); border-color: var(--green); }

    /* SUMMARY CARD */
    .summary-card { background: rgba(0,194,122,0.08); border: 1px solid rgba(0,194,122,0.2); border-radius: 20px; padding: 2rem; margin-bottom: 2rem; }
    .summary-card h3 { font-size: 1.1rem; color: var(--white); margin-bottom: 1.25rem; font-weight: 700; }
    .summary-row { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 0.88rem; }
    .summary-row:last-child { border-bottom: none; }
    .summary-row .label { color: var(--muted); }
    .summary-row .val { color: var(--white); font-weight: 700; text-align: right; }
    .summary-highlight { font-family: 'Fraunces', serif; font-size: 2.5rem; font-weight: 900; color: var(--green); text-align: center; margin: 1rem 0 0.25rem; }
    .summary-highlight-sub { text-align: center; font-size: 0.82rem; color: var(--muted); margin-bottom: 1.25rem; }

    /* BUTTONS */
    .btn-next { width: 100%; padding: 1.1rem; background: var(--green); color: var(--dark); font-weight: 700; font-size: 1rem; border: none; border-radius: 100px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.25s; box-shadow: 0 0 30px rgba(0,194,122,0.25); }
    .btn-next:hover { background: var(--green-d); transform: translateY(-1px); box-shadow: 0 0 50px rgba(0,194,122,0.4); }
    .btn-next:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-back { width: 100%; padding: 0.9rem; background: transparent; color: var(--muted); font-weight: 600; font-size: 0.9rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; cursor: pointer; font-family: 'DM Sans', sans-serif; margin-top: 0.75rem; transition: all 0.2s; }
    .btn-back:hover { border-color: rgba(255,255,255,0.25); color: var(--text); }
    .btn-group { display: flex; flex-direction: column; gap: 0.5rem; }

    /* LOADING */
    .loading-overlay { position: fixed; inset: 0; background: var(--dark); z-index: 999; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.5rem; }
    .loading-overlay.hidden { display: none; }
    .spinner { width: 48px; height: 48px; border: 3px solid rgba(0,194,122,0.2); border-top-color: var(--green); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-text { font-family: 'Fraunces', serif; font-size: 1.4rem; color: var(--white); }
    .loading-sub { font-size: 0.85rem; color: var(--muted); }

    /* ERROR MESSAGE */
    .msg-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; border-radius: 10px; padding: 0.75rem 1rem; font-size: 0.83rem; margin-bottom: 1rem; display: none; }
    .msg-error.show { display: block; }
  </style>
</head>
<body>

<div class="bg-glow"></div>

<!-- Loading overlay -->
<div id="loading-overlay" class="loading-overlay">
  <div class="spinner"></div>
  <div class="loading-text">Verificando acesso...</div>
  <div class="loading-sub">Só um momento</div>
</div>

<!-- Header -->
<header>
  <a href="index.html" class="logo">Crono<span>Med</span></a>
  <div class="header-step" id="header-step">Passo 1 de 5</div>
</header>

<!-- Main content -->
<div class="container">
  <!-- Progress bar -->
  <div class="progress-track">
    <div class="progress-fill" id="progress-fill" style="width: 20%"></div>
  </div>

  <div class="msg-error" id="global-error"></div>

  <!-- ═══ PASSO 1 — QUEM É VOCÊ ═══ -->
  <div class="step-panel active" id="step-1">
    <div class="step-badge">✦ Passo 1 de 5</div>
    <h1 class="step-title">Vamos personalizar<br /><em>seu</em> cronograma</h1>
    <p class="step-sub">Em menos de 2 minutos vamos montar um cronograma com o número exato de semanas que você tem disponíveis.</p>

    <div class="field">
      <label>Como você se chama?</label>
      <input type="text" id="f-nome" placeholder="Seu nome completo" />
    </div>

    <div class="field">
      <label>Qual prova vai prestar?</label>
      <select id="f-prova">
        <option value="">Selecione...</option>
        <option value="residencia">Residência Médica</option>
        <option value="revalida">Revalida</option>
        <option value="ambos">Residência + Revalida</option>
        <option value="outro">Outro concurso médico</option>
      </select>
    </div>

    <div class="btn-group">
      <button class="btn-next" onclick="goStep(2)">Continuar →</button>
    </div>
  </div>

  <!-- ═══ PASSO 2 — DATAS ═══ -->
  <div class="step-panel" id="step-2">
    <div class="step-badge">📅 Passo 2 de 5</div>
    <h1 class="step-title">Quando começa<br />sua jornada?</h1>
    <p class="step-sub">Com as datas de início e da prova, calculamos exatamente quantas semanas você tem para estudar.</p>

    <div class="field">
      <label>Quando quer começar a estudar?</label>
      <input type="date" id="f-inicio" oninput="calcWeeks()" />
    </div>

    <div class="field">
      <label>Quando é sua prova? (data aproximada)</label>
      <input type="date" id="f-prova-data" oninput="calcWeeks()" />
    </div>

    <!-- Dynamic week preview -->
    <div class="week-preview hidden" id="week-preview">
      <div class="week-preview-num" id="wp-num">–</div>
      <div class="week-preview-label" id="wp-label">
        <strong id="wp-title">Calculando...</strong>
        <span id="wp-range"></span>
      </div>
    </div>

    <div class="btn-group">
      <button class="btn-next" id="btn-step2" onclick="goStep(3)" disabled>Continuar →</button>
      <button class="btn-back" onclick="goStep(1)">← Voltar</button>
    </div>
  </div>

  <!-- ═══ PASSO 3 — INTERNATO ═══ -->
  <div class="step-panel" id="step-3">
    <div class="step-badge">🏥 Passo 3 de 5</div>
    <h1 class="step-title">Você está no<br />internato?</h1>
    <p class="step-sub">Se estiver, informe seus rodízios para que o cronograma seja distribuído respeitando sua grade hospitalar.</p>

    <div class="options-grid" id="internato-opcao">
      <div class="option-card" onclick="selectOption('internato-opcao', 'sim', this)">
        <span class="option-emoji">🩺</span>
        <div class="option-radio"></div>
        <div>
          <div class="option-title">Sim, estou no internato</div>
          <div class="option-desc">Vou informar meus rodízios e datas</div>
        </div>
      </div>
      <div class="option-card" onclick="selectOption('internato-opcao', 'nao', this)">
        <span class="option-emoji">📚</span>
        <div class="option-radio"></div>
        <div>
          <div class="option-title">Não, só estou estudando</div>
          <div class="option-desc">Tenho tempo livre para estudar todos os dias</div>
        </div>
      </div>
    </div>

    <!-- Rodízios (aparece só se "sim") -->
    <div id="rodizios-section" class="hidden">
      <div class="field">
        <label>Seus rodízios (área + período)</label>
      </div>
      <div class="internato-list" id="internato-list">
        <!-- rows added dynamically -->
      </div>
      <button class="btn-add-internato" onclick="addInternato()">+ Adicionar rodízio</button>
    </div>

    <div class="btn-group">
      <button class="btn-next" id="btn-step3" onclick="goStep(4)" disabled>Continuar →</button>
      <button class="btn-back" onclick="goStep(2)">← Voltar</button>
    </div>
  </div>

  <!-- ═══ PASSO 4 — RITMO ═══ -->
  <div class="step-panel" id="step-4">
    <div class="step-badge">⏱️ Passo 4 de 5</div>
    <h1 class="step-title">Qual é o seu<br />ritmo diário?</h1>
    <p class="step-sub">Isso nos ajuda a calibrar quantas matérias distribuir por semana.</p>

    <div class="options-grid" id="ritmo-opcao">
      <div class="option-card" onclick="selectOption('ritmo-opcao', '1-2h', this)">
        <span class="option-emoji">🌱</span>
        <div class="option-radio"></div>
        <div>
          <div class="option-title">1 a 2 horas por dia</div>
          <div class="option-desc">Estudo mais leve, conciliar com outras atividades</div>
        </div>
      </div>
      <div class="option-card" onclick="selectOption('ritmo-opcao', '3-4h', this)">
        <span class="option-emoji">🔥</span>
        <div class="option-radio"></div>
        <div>
          <div class="option-title">3 a 4 horas por dia</div>
          <div class="option-desc">Ritmo equilibrado — o mais comum entre os aprovados</div>
        </div>
      </div>
      <div class="option-card" onclick="selectOption('ritmo-opcao', '5h+', this)">
        <span class="option-emoji">🚀</span>
        <div class="option-radio"></div>
        <div>
          <div class="option-title">5 horas ou mais</div>
          <div class="option-desc">Dedicação máxima, estou focado só nisso</div>
        </div>
      </div>
    </div>

    <div class="btn-group">
      <button class="btn-next" id="btn-step4" onclick="goStep(5)" disabled>Continuar →</button>
      <button class="btn-back" onclick="goStep(3)">← Voltar</button>
    </div>
  </div>

  <!-- ═══ PASSO 5 — RESUMO + CONFIRMAR ═══ -->
  <div class="step-panel" id="step-5">
    <div class="step-badge">✅ Passo 5 de 5</div>
    <h1 class="step-title">Tudo pronto.<br />Veja seu plano.</h1>
    <p class="step-sub">Confirme os dados abaixo. Você poderá ajustar tudo depois dentro do cronograma.</p>

    <div class="summary-card">
      <div class="summary-highlight" id="sum-semanas">– semanas</div>
      <div class="summary-highlight-sub" id="sum-range">de – a –</div>

      <div class="summary-row">
        <span class="label">Nome</span>
        <span class="val" id="sum-nome">–</span>
      </div>
      <div class="summary-row">
        <span class="label">Prova</span>
        <span class="val" id="sum-prova">–</span>
      </div>
      <div class="summary-row">
        <span class="label">Início dos estudos</span>
        <span class="val" id="sum-inicio">–</span>
      </div>
      <div class="summary-row">
        <span class="label">Data da prova</span>
        <span class="val" id="sum-prova-data">–</span>
      </div>
      <div class="summary-row">
        <span class="label">Horas por dia</span>
        <span class="val" id="sum-horas">–</span>
      </div>
      <div class="summary-row">
        <span class="label">Internato</span>
        <span class="val" id="sum-internato">–</span>
      </div>
    </div>

    <div class="msg-error" id="save-error"></div>

    <div class="btn-group">
      <button class="btn-next" id="btn-iniciar" onclick="confirmarOnboarding()">
        Começar minha jornada →
      </button>
      <button class="btn-back" onclick="goStep(4)">← Voltar</button>
    </div>
  </div>

</div>

<script>
  // ── CONFIG ────────────────────────────────────────────────────────────────
  const SB_URL = 'https://pdfzoimdonoikrhtwmym.supabase.co';
  const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBkZnpvaW1kb25vaWtyaHR3bXltIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU2OTUxMDYsImV4cCI6MjA5MTI3MTEwNn0.xy7MNY0U9hawd4Lvz6pFq4x4gVyQAbcPoTXoCbiIpdw';

  const { createClient } = supabase;
  const sb = createClient(SB_URL, SB_KEY);

  let currentStep = 1;
  let selectedValues = { internato: null, ritmo: null };
  let weekCount = 0;
  let currentUser = null;

  // ── AUTH CHECK ────────────────────────────────────────────────────────────
  (async () => {
    const { data: { session } } = await sb.auth.getSession();
    if (!session) { window.location.href = 'index.html'; return; }

    currentUser = session.user;

    // Check if onboarding already done
    const { data: ob } = await sb.from('onboarding')
      .select('completed').eq('user_id', currentUser.id).single();

    if (ob && ob.completed) {
      // Already onboarded → go to cronograma
      window.location.href = 'cronograma.html';
      return;
    }

    // Check access
    const { data: profile } = await sb.from('profiles')
      .select('acesso_liberado, nome').eq('id', currentUser.id).single();

    if (!profile || !profile.acesso_liberado) {
      window.location.href = 'index.html';
      return;
    }

    // Pre-fill name if available
    if (profile.nome) document.getElementById('f-nome').value = profile.nome;

    // Set default dates (today + 6 months)
    const today = new Date();
    const sixMonths = new Date(today);
    sixMonths.setMonth(today.getMonth() + 6);
    document.getElementById('f-inicio').value = today.toISOString().split('T')[0];
    document.getElementById('f-prova-data').value = sixMonths.toISOString().split('T')[0];
    calcWeeks();

    document.getElementById('loading-overlay').classList.add('hidden');
  })();

  // ── NAVIGATION ────────────────────────────────────────────────────────────
  function goStep(n) {
    if (n > currentStep && !validateStep(currentStep)) return;

    document.getElementById(`step-${currentStep}`).classList.remove('active');
    document.getElementById(`step-${n}`).classList.add('active');
    currentStep = n;

    // Update progress
    const pct = (n / 5) * 100;
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('header-step').textContent = `Passo ${n} de 5`;

    // Populate summary on step 5
    if (n === 5) populateSummary();

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── VALIDATION ────────────────────────────────────────────────────────────
  function validateStep(step) {
    const err = document.getElementById('global-error');
    err.classList.remove('show');

    if (step === 1) {
      const nome = document.getElementById('f-nome').value.trim();
      const prova = document.getElementById('f-prova').value;
      if (!nome) { showErr(err, 'Por favor, informe seu nome.'); return false; }
      if (!prova) { showErr(err, 'Selecione qual prova vai prestar.'); return false; }
    }
    if (step === 2) {
      const inicio = document.getElementById('f-inicio').value;
      const prova  = document.getElementById('f-prova-data').value;
      if (!inicio || !prova) { showErr(err, 'Preencha as duas datas.'); return false; }
      if (new Date(prova) <= new Date(inicio)) { showErr(err, 'A data da prova deve ser depois do início.'); return false; }
      if (weekCount < 4) { showErr(err, 'O intervalo precisa ser de pelo menos 4 semanas.'); return false; }
    }
    if (step === 3) {
      if (!selectedValues.internato) { showErr(err, 'Selecione uma opção de internato.'); return false; }
    }
    if (step === 4) {
      if (!selectedValues.ritmo) { showErr(err, 'Selecione seu ritmo de estudos.'); return false; }
    }
    return true;
  }

  function showErr(el, msg) { el.textContent = msg; el.classList.add('show'); }

  // ── WEEK CALCULATOR ───────────────────────────────────────────────────────
  function calcWeeks() {
    const inicio = document.getElementById('f-inicio').value;
    const prova  = document.getElementById('f-prova-data').value;
    const preview = document.getElementById('week-preview');
    const btn = document.getElementById('btn-step2');

    if (!inicio || !prova) { preview.classList.add('hidden'); btn.disabled = true; return; }

    const d1 = new Date(inicio + 'T00:00:00');
    const d2 = new Date(prova  + 'T00:00:00');
    const diffMs = d2 - d1;

    if (diffMs <= 0) { preview.classList.add('hidden'); btn.disabled = true; return; }

    weekCount = Math.floor(diffMs / (7 * 24 * 60 * 60 * 1000));
    const fmt = d => d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' });

    const wpNum   = document.getElementById('wp-num');
    const wpTitle = document.getElementById('wp-title');
    const wpRange = document.getElementById('wp-range');
    const wpLabel = document.getElementById('wp-label');

    wpNum.textContent = weekCount;
    wpRange.textContent = `${fmt(d1)} até ${fmt(d2)}`;

    if (weekCount < 4) {
      wpTitle.textContent = 'Intervalo muito curto';
      wpLabel.className = 'week-preview-label warn';
      btn.disabled = true;
    } else if (weekCount > 100) {
      wpTitle.textContent = 'Intervalo muito longo';
      wpLabel.className = 'week-preview-label warn';
      btn.disabled = true;
    } else {
      wpTitle.textContent = `semanas de estudo`;
      wpLabel.className = 'week-preview-label';
      btn.disabled = false;
    }

    preview.classList.remove('hidden');
  }

